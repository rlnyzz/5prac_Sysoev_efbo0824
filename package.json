{
  "name": "digital-store-api",
  "version": "1.0.0",
  "description": "Интернет-магазин цифровой техники Сысоева Виталия с Swagger документацией REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npx react-scripts start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npx react-scripts build",
    "sass": "sass src:src --watch",
    "swagger": "node server.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9",
    "react-scripts": "5.0.1",
    "sass": "^1.85.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3000",
  "keywords": [
    "rest-api",
    "swagger",
    "openapi",
    "express",
    "react",
    "digital-store",
    "e-commerce"
  ],
  "author": "Сысоев Виталий",
  "license": "ISC"
}